{
  "manifest_version": 3,
  "name": "YouTube Categories",
  "version": "1.2",
  "description": "Select a YouTube category to get the top 5 rated video links.",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
